	<Button name="GoldMaker_Icon" hidden="false" parent="UIParent" movable="false" enableMouse="true" frameStrata="HIGH">
		<Size>
			<AbsDimension y="28" x="26"/>
		</Size>
		<Anchors>
			<Anchor point="TOPRIGHT" relativePoint="BOTTOMLEFT" relativeTo="MinimapViewFrame" x="-29" y="-20"/>
		</Anchors>
		<Scripts>
			<OnLoad>
				this:RegisterForClicks("LeftButton", "MiddleButton", "RightButton");
			</OnLoad>
			<OnEnter>
				GameTooltip:SetOwner(this,"ANCHOR_TOPRIGHT",0,0);
				GameTooltip:SetText( "|cffFFD700Gold Maker|r" );
				GameTooltip:AddLine(UI_GROUP_LOOT_FRAME_MOVE_TOOLTIP, 0, 0.75, 0.95)
				GameTooltip:Show();
			</OnEnter>
			<OnClick>
				if not IsShiftKeyDown() then
					ToggleUIFrame(GoldMaker);
				end
			</OnClick>
			<OnLeave>
				GameTooltip:Hide();
			</OnLeave>
			<OnMouseDown>
				GoldMaker_Icon_OnMouseDown( this, key );
			</OnMouseDown>
			<OnMouseUp>
				GoldMaker_Icon_OnMouseUp( this );
			</OnMouseUp>
		</Scripts>
		<NormalTexture file="Interface\addons\GoldMaker\icons\icon.tga"/>
		<PushedTexture file="Interface\addons\GoldMaker\icons\iconP.tga"/>
		<HighlightTexture file="Interface\addons\GoldMaker\icons\iconH.tga"/>
	</Button>

